{
  "name": "fastify-boilerplate",
  "version": "1.0.0",
  "description": "The Fastify boilerplate with all you need to build your SaaS, AI tool, or any other web app and make your first $ online fast.",
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/main.ts",
    "lint": "prettier --write --config prettier.config.js --list-different src/**/*.ts",
    "start": "node dist/main.js",
    "test": "jest"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24.13.3",
    "@types/qs": "^6.15.1",
    "jest": "^30.4.2",
    "prettier": "^3.9.4",
    "ts-jest": "^29.4.11",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@faker-js/faker": "^10.5.0",
    "@fastify/cors": "^11.3.0",
    "@fastify/swagger": "^9.8.0",
    "@fastify/swagger-ui": "^6.0.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.10.0",
    "mongodb": "^7.5.0",
    "qs": "^6.15.3"
  }
}
